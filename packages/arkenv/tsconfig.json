{
	"compilerOptions": {
		"target": "es2020",
		"module": "preserve",
		"strict": true,
		"esModuleInterop": true,
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"exactOptionalPropertyTypes": true,
		"noImplicitAny": true,
		"noEmit": true,
		"outDir": "dist",
		"resolveJsonModule": true,
		"rootDir": "src",
		"paths": {
			"@/*": ["./src/*"],
			"@/": ["./src/index.ts"]
		},
		"declaration": true,
		"declarationMap": true,
		"allowImportingTsExtensions": true,
		"types": ["node"],
		"lib": ["es2020", "es2022.object"]
	},
	"include": ["src"]
}
