{
	"name": "arkenv",
	"type": "module",
	"version": "1.0.0-alpha.1",
	"description": "Typesafe environment variables parsing and validation with ArkType",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.mts",
				"require": "./dist/index.d.cts"
			},
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./standard": {
			"types": {
				"import": "./dist/standard.d.mts",
				"require": "./dist/standard.d.cts"
			},
			"import": "./dist/standard.mjs",
			"require": "./dist/standard.cjs"
		},
		"./core": {
			"types": {
				"import": "./dist/core.d.mts",
				"require": "./dist/core.d.cts"
			},
			"import": "./dist/core.mjs",
			"require": "./dist/core.cjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"size": "size-limit --json > .size-limit.json",
		"test:once": "vitest run",
		"test:dist": "vitest run test/dist.test.ts",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist node_modules",
		"test": "vitest",
		"test:types": "vitest run --typecheck.only",
		"fix": "pnpm -w run fix"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"pnpm",
		"arktype",
		"environment",
		"variables",
		"typesafe",
		"validation"
	],
	"license": "MIT",
	"homepage": "https://arkenv.js.org",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yamcodes/arkenv.git"
	},
	"bugs": "https://github.com/yamcodes/arkenv/labels/arkenv",
	"author": "Yam Borodetsky <yam@yam.codes>",
	"devDependencies": {
		"@ark/attest": "catalog:",
		"@repo/scope": "workspace:*",
		"@repo/types": "workspace:*",
		"@size-limit/esbuild-why": "catalog:",
		"@size-limit/preset-small-lib": "catalog:",
		"@types/node": "catalog:",
		"arktype": "catalog:",
		"rimraf": "catalog:",
		"size-limit": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"zod": "catalog:"
	},
	"peerDependencies": {
		"arktype": "^2.1.22"
	},
	"peerDependenciesMeta": {
		"arktype": {
			"optional": true
		}
	},
	"size-limit": [
		{
			"name": "arkenv",
			"path": "dist/index.mjs",
			"limit": "2.6 kB",
			"import": "*",
			"ignore": [
				"arktype"
			]
		},
		{
			"name": "arkenv/standard",
			"path": "dist/standard.mjs",
			"limit": "3.5 kB",
			"import": "*"
		},
		{
			"name": "arkenv/core",
			"path": "dist/core.mjs",
			"limit": "500 B",
			"import": "*"
		}
	]
}
