{
	"name": "@repo/utils",
	"private": true,
	"type": "module",
	"version": "0.1.3",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
