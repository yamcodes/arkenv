{
	"name": "@arkenv/cli",
	"type": "module",
	"version": "0.2.6",
	"description": "Interactive CLI for scaffolding ArkEnv projects",
	"bin": {
		"arkenv": "./dist/index.cjs"
	},
	"main": "./dist/index.cjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./*": "./dist/*"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"start": "node ./dist/index.cjs init",
		"dev": "tsdown --watch",
		"test": "vitest",
		"test:run": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"arkenv",
		"cli",
		"scaffold",
		"init"
	],
	"license": "MIT",
	"homepage": "https://arkenv.js.org",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yamcodes/arkenv.git"
	},
	"bugs": "https://github.com/yamcodes/arkenv/labels/arkenv-cli",
	"author": "Yam Borodetsky <yam@yam.codes>",
	"dependencies": {
		"@clack/prompts": "^1.3.0",
		"dedent": "^1.7.2",
		"jsonc-parser": "^3.3.1",
		"magicast": "^0.5.2",
		"picocolors": "^1.1.1",
		"radashi": "^12.9.1"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	}
}
