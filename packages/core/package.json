{
	"name": "@arkenv/core",
	"type": "module",
	"version": "1.0.0-alpha.4",
	"description": "Typesafe environment variables parsing and validation with ArkType",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.mts",
				"require": "./dist/index.d.cts"
			},
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"size": "size-limit --json > .size-limit.json",
		"test:once": "vitest run",
		"test:dist": "vitest run test/dist.test.ts",
		"typecheck": "tsc --noEmit",
		"clean": "rimraf dist node_modules",
		"test": "vitest",
		"test:types": "vitest run --typecheck.only",
		"fix": "pnpm -w run fix"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"env",
		"environment-variables",
		"environment",
		"variables",
		"dotenv",
		"config",
		"validation",
		"typesafe",
		"standard-schema",
		"arktype"
	],
	"license": "MIT",
	"homepage": "https://arkenv.js.org",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yamcodes/arkenv.git"
	},
	"bugs": "https://github.com/yamcodes/arkenv/labels/arkenv",
	"author": "Yam Borodetsky <yam@yam.codes>",
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@ark/attest": "catalog:",
		"@arkenv/standard": "workspace:*",
		"@repo/scope": "workspace:*",
		"@repo/types": "workspace:*",
		"@repo/utils": "workspace:*",
		"@size-limit/esbuild-why": "catalog:",
		"@size-limit/preset-small-lib": "catalog:",
		"@types/node": "catalog:",
		"arktype": "catalog:",
		"rimraf": "catalog:",
		"size-limit": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"zod": "catalog:"
	},
	"peerDependencies": {
		"arktype": "^2.1.22"
	},
	"size-limit": [
		{
			"name": "@arkenv/core",
			"path": "dist/index.mjs",
			"limit": "2.7 kB",
			"import": "*",
			"ignore": [
				"arktype"
			]
		}
	]
}
