{
	"name": "@arkenv/fumadocs-ui",
	"version": "0.0.7",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yamcodes/arkenv.git"
	},
	"exports": {
		"./css/*": "./css/*",
		"./mdx": {
			"types": {
				"import": "./dist/mdx/index.d.mts",
				"require": "./dist/mdx/index.d.cts"
			},
			"import": "./dist/mdx/index.mjs",
			"require": "./dist/mdx/index.cjs"
		},
		"./components": {
			"types": {
				"import": "./dist/components/index.d.mts",
				"require": "./dist/components/index.d.cts"
			},
			"import": "./dist/components/index.mjs",
			"require": "./dist/components/index.cjs"
		},
		"./utils": {
			"types": {
				"import": "./dist/utils/index.d.mts",
				"require": "./dist/utils/index.d.cts"
			},
			"import": "./dist/utils/index.mjs",
			"require": "./dist/utils/index.cjs"
		}
	},
	"files": [
		"css/*",
		"dist/*"
	],
	"scripts": {
		"dev": "tsdown --watch",
		"build": "tsdown",
		"clean": "rimraf dist",
		"typecheck": "tsc --noEmit",
		"fix": "pnpm -w run fix"
	},
	"dependencies": {
		"clsx": "2.1.1",
		"tailwind-merge": "3.5.0"
	},
	"peerDependencies": {
		"@fumadocs/ui": "16.5.0",
		"fumadocs-core": "16.7.11",
		"fumadocs-ui": "16.7.11",
		"lucide-react": "1.7.0",
		"next": ">=16.2.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"tailwindcss": "4.2.2"
	},
	"devDependencies": {
		"@fumadocs/ui": "16.5.0",
		"@types/mdx": "2.0.13",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"fumadocs-core": "16.7.11",
		"fumadocs-ui": "16.7.11",
		"lucide-react": "1.7.0",
		"next": "catalog:",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"rimraf": "catalog:",
		"rollup-plugin-preserve-use-client": "3.0.1",
		"tailwindcss": "4.2.2",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	},
	"publishConfig": {
		"access": "public"
	}
}
