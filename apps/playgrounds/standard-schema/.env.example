# Required
DATABASE_URL=           # A valid URL (e.g. https://db.example.com)
API_KEY=                # At least 32 characters
ALLOWED_ORIGINS=        # Comma-separated list of URLs (e.g. https://example.com,https://app.example.com)

# Optional (have defaults)
# MAX_RETRIES=3         # Positive integer, default: 3
# TIMEOUT_MS=5000       # 0–30000 ms, default: 5000
# NODE_ENV=development  # "development" | "production" | "test", default: "development"
# DEBUG=false           # true/false/1/0, default: false
# PORT=3000             # 0–65535, default: 3000
