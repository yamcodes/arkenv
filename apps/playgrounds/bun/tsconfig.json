{
	"compilerOptions": {
		// Environment setup & latest features
		"lib": ["ESNext"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,

		// Bundler mode
		"moduleResolution": "node",		
   		lowImportingTsExtensions": true,
   		rbatimModuleSyntax": true,
    "noEmit": true,
		
   		Best practices
   		rict": true,
   		ipLibCheck": true,
   		FallthroughCasesInSwitch": true,
   		UncheckedIndexedAccess": true,
    "noImplicitOverride": true,
		
   		Some stricter flags (disabled by default)
   		UnusedLocals": false,
   		UnusedParameters": false,
   	 }
}
